{
  "expo": {
    "name": "SongLayer",
    "slug": "songlayer",
    "version": "1.0.0",
    "scheme": "songlayer",
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-localization",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true,
      "buildCacheProvider": {
        "plugin": "expo-build-disk-cache"
      },
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.songlayer.www",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "SongLayer needs camera access to record your video takes.",
        "NSMicrophoneUsageDescription": "SongLayer needs microphone access to record your audio takes.",
        "NSPhotoLibraryAddUsageDescription": "SongLayer saves your finished videos to your photo library.",
        "UIBackgroundModes": ["audio", "processing"],
        "BGTaskSchedulerPermittedIdentifiers": ["app.songlayer.export"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.songlayer.www",
      "predictiveBackGestureEnabled": true,
      "permissions": ["CAMERA", "RECORD_AUDIO", "WRITE_EXTERNAL_STORAGE", "READ_MEDIA_VIDEO"]
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
